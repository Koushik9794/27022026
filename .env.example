# Root-level environment configuration for all GSS Backend services
# Copy this file to .env and update with your local settings
# IMPORTANT: Never commit .env file to version control

# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================

DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres

# Admin Service Database
ADMIN_DB_NAME=admin_service
ADMIN_CONNECTION_STRING=Host=postgres;Database=admin_service;Username=postgres;Password=postgres;Port=5432;

# Catalog Service Database
CATALOG_DB_NAME=catalog_service
CATALOG_CONNECTION_STRING=Host=postgres;Database=catalog_service;Username=postgres;Password=postgres;Port=5432;

# Rule Service Database
RULE_DB_NAME=rule_service
RULE_CONNECTION_STRING=Host=postgres;Database=rule_service;Username=postgres;Password=postgres;Port=5432;

# File Service Database
FILE_DB_NAME=file_service
FILE_CONNECTION_STRING=Host=postgres;Database=file_service;Username=postgres;Password=postgres;Port=5432;

# Configuration Service Database
CONFIG_DB_NAME=configuration_service
CONFIG_CONNECTION_STRING=Host=postgres;Database=configuration_service;Username=postgres;Password=postgres;Port=5432;

# BOM Service Database
BOM_DB_NAME=bom_service
BOM_CONNECTION_STRING=Host=postgres;Database=bom_service;Username=postgres;Password=postgres;Port=5432;

# ============================================================================
# Application Configuration
# ============================================================================

ASPNETCORE_ENVIRONMENT=Development

# Service Ports
ADMIN_SERVICE_PORT=5001
CATALOG_SERVICE_PORT=5002
RULE_SERVICE_PORT=5000
FILE_SERVICE_PORT=5003
CONFIG_SERVICE_PORT=5004
BOM_SERVICE_PORT=5005

# ============================================================================
# Storage Configuration (for File Service)
# ============================================================================

STORAGE_TYPE=MinIO
S3_BUCKET_NAME=gss-files
S3_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# File Upload Limits
MAX_FILE_SIZE_MB=100
ALLOWED_FILE_TYPES=.glb,.xlsx,.csv,.json,.pdf

# ============================================================================
# Service Integration URLs
# ============================================================================

CATALOG_SERVICE_URL=http://catalog_service:5002
CONFIGURATION_SERVICE_URL=http://configuration_service:5004
RULE_SERVICE_URL=http://rule_service:5000
FILE_SERVICE_URL=http://file_service:5003
ADMIN_SERVICE_URL=http://admin_service:5001
BOM_SERVICE_URL=http://bom_service:5005

# ============================================================================
# Logging Configuration
# ============================================================================

LOG_LEVEL=Information
SEQ_URL=http://seq:5341

# ============================================================================
# Development Tools
# ============================================================================

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_CONSOLE_PORT=9001
MINIO_API_PORT=9000

# Seq (Logging)
SEQ_PORT=8081
SEQ_API_PORT=5341
