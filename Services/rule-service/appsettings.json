{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=rule_service;User Id=postgres;Password=postgres;"
  },
  "RuleEngine": {
    "ExpressionEngineType": "DynamicExpresso",
    "MaxEvaluationTimeMs": 5000,
    "CacheRuleResults": true,
    "CacheDurationMinutes": 60
  },
  "Swagger": {
    "Enabled": true,
    "Version": "1.0.0",
    "Title": "GSS Rule Service API"
  }
}
