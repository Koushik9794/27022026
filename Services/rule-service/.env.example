# Rule Service Environment Variables - LOCAL DEVELOPMENT TEMPLATE
# Copy this to .env and fill in actual values
# DO NOT COMMIT .env to version control!

# Database Connection (Local PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rule_service
DB_USER=postgres
DB_PASSWORD=postgres
CONNECTION_STRING=Server=localhost;Database=rule_service;User Id=postgres;Password=postgres;Port=5432;

# Application Settings
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000
LOG_LEVEL=Information

# Rule Engine Configuration
RULE_ENGINE_TYPE=DynamicExpresso
MAX_EVALUATION_TIME_MS=5000
CACHE_RULE_RESULTS=true
CACHE_DURATION_MINUTES=60

# API Configuration
API_PORT=5000
ENABLE_SWAGGER=true
ENABLE_CORS=true

# AWS Configuration (if using AWS services)
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# For Fargate RDS (uncomment and fill for production)
# DB_HOST=rule-service-db.xxxxx.rds.amazonaws.com
# DB_USER=postgres
# DB_PASSWORD=YourSecurePassword123!
# CONNECTION_STRING=Server=rule-service-db.xxxxx.rds.amazonaws.com;Database=rule_service;User Id=postgres;Password=YourSecurePassword123!;Port=5432;SSL Mode=Require;
