{
  "info": {
    "name": "GSS Rule Service - Manifest API",
    "description": "Comprehensive test collection for Rule Manifest and Matrix endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5001",
      "type": "string"
    },
    {
      "key": "productGroupId",
      "value": "11111111-1111-1111-1111-111111111111",
      "type": "string"
    },
    {
      "key": "countryId",
      "value": "22222222-2222-2222-2222-222222222222",
      "type": "string"
    },
    {
      "key": "matrixId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Rule Manifest",
      "item": [
        {
          "name": "Get Manifest - Valid Product and Country",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has manifest structure\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('version');",
                  "    pm.expect(jsonData).to.have.property('productGroupId');",
                  "    pm.expect(jsonData).to.have.property('countryId');",
                  "    pm.expect(jsonData).to.have.property('rules');",
                  "    pm.expect(jsonData).to.have.property('matrices');",
                  "    pm.expect(jsonData).to.have.property('generatedAt');",
                  "});",
                  "",
                  "pm.test(\"Rules array is not empty\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.rules).to.be.an('array');",
                  "    pm.expect(jsonData.rules.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test(\"Each rule has required fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    jsonData.rules.forEach(function(rule) {",
                  "        pm.expect(rule).to.have.property('id');",
                  "        pm.expect(rule).to.have.property('name');",
                  "        pm.expect(rule).to.have.property('category');",
                  "        pm.expect(rule).to.have.property('severity');",
                  "        pm.expect(rule).to.have.property('priority');",
                  "    });",
                  "});",
                  "",
                  "pm.test(\"Version format is correct\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.version).to.match(/^\\d{8}\\.\\d{4}$/);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/rules/manifest?productGroupId={{productGroupId}}&countryId={{countryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "rules", "manifest"],
              "query": [
                {
                  "key": "productGroupId",
                  "value": "{{productGroupId}}"
                },
                {
                  "key": "countryId",
                  "value": "{{countryId}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Manifest - Non-existent Product Group",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 404\", function () {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test(\"Error message is present\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('message');",
                  "    pm.expect(jsonData.message).to.include('No active ruleset');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/rules/manifest?productGroupId=99999999-9999-9999-9999-999999999999&countryId={{countryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "rules", "manifest"],
              "query": [
                {
                  "key": "productGroupId",
                  "value": "99999999-9999-9999-9999-999999999999"
                },
                {
                  "key": "countryId",
                  "value": "{{countryId}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Manifest - Verify Rule Conditions",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"At least one rule has conditions\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var hasConditions = jsonData.rules.some(rule => rule.conditions && rule.conditions.length > 0);",
                  "    pm.expect(hasConditions).to.be.true;",
                  "});",
                  "",
                  "pm.test(\"Conditions have correct structure\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var ruleWithConditions = jsonData.rules.find(rule => rule.conditions && rule.conditions.length > 0);",
                  "    if (ruleWithConditions) {",
                  "        ruleWithConditions.conditions.forEach(function(condition) {",
                  "            pm.expect(condition).to.have.property('field');",
                  "            pm.expect(condition).to.have.property('operator');",
                  "            pm.expect(condition).to.have.property('value');",
                  "        });",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/rules/manifest?productGroupId={{productGroupId}}&countryId={{countryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "rules", "manifest"],
              "query": [
                {
                  "key": "productGroupId",
                  "value": "{{productGroupId}}"
                },
                {
                  "key": "countryId",
                  "value": "{{countryId}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Manifest - Verify Matrix Metadata",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Matrices array exists\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('matrices');",
                  "    pm.expect(jsonData.matrices).to.be.an('array');",
                  "});",
                  "",
                  "pm.test(\"Each matrix has metadata\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.matrices.length > 0) {",
                  "        jsonData.matrices.forEach(function(matrix) {",
                  "            pm.expect(matrix).to.have.property('name');",
                  "            pm.expect(matrix).to.have.property('category');",
                  "            pm.expect(matrix).to.have.property('version');",
                  "        });",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/rules/manifest?productGroupId={{productGroupId}}&countryId={{countryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "rules", "manifest"],
              "query": [
                {
                  "key": "productGroupId",
                  "value": "{{productGroupId}}"
                },
                {
                  "key": "countryId",
                  "value": "{{countryId}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Matrix Operations",
      "item": [
        {
          "name": "Get Matrix by Name",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Matrix has required fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('name');",
                  "    pm.expect(jsonData).to.have.property('category');",
                  "    pm.expect(jsonData).to.have.property('dataJson');",
                  "    pm.expect(jsonData).to.have.property('version');",
                  "});",
                  "",
                  "pm.test(\"Data is valid JSON\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(function() { JSON.parse(jsonData.dataJson); }).to.not.throw();",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/matrices/BeamChart",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "matrices", "BeamChart"]
            }
          },
          "response": []
        },
        {
          "name": "Get Matrix Choices",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Choices array is returned\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});",
                  "",
                  "pm.test(\"Each choice has required fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.length > 0) {",
                  "        jsonData.forEach(function(choice) {",
                  "            pm.expect(choice).to.have.property('choiceId');",
                  "            pm.expect(choice).to.have.property('capacity');",
                  "            pm.expect(choice).to.have.property('utilization');",
                  "            pm.expect(choice).to.have.property('isSafe');",
                  "        });",
                  "    }",
                  "});",
                  "",
                  "pm.test(\"Choices are sorted by utilization\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.length > 1) {",
                  "        for (var i = 0; i < jsonData.length - 1; i++) {",
                  "            pm.expect(jsonData[i].utilization).to.be.at.most(jsonData[i + 1].utilization);",
                  "        }",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/matrices/BeamChart/choices?uprightId=ST20&span=2750&load=1500",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "matrices", "BeamChart", "choices"],
              "query": [
                {
                  "key": "uprightId",
                  "value": "ST20"
                },
                {
                  "key": "span",
                  "value": "2750"
                },
                {
                  "key": "load",
                  "value": "1500"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Matrix Cell",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 204\", function () {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"path\": [\"uprights\", \"ST20\", \"2700\", \"HEM_80\"],\n  \"value\": 2100\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/matrices/{{matrixId}}/cell",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "matrices", "{{matrixId}}", "cell"]
            }
          },
          "response": []
        }
      ]
    },
