{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "FileValidation": {
        "MaxFileSizeMb": 50,
        "AllowedExtensions": [
            ".dxf",
            ".pdf",
            ".xlsx",
            ".png",
            ".jpg",
            ".json",
            ".glb"
        ],
        "MagicNumberCheck": false,
        "LocalStoragePath": "uploads"
    }
}