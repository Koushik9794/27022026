{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "ServiceEndpoints": {
    "AdminService": "http://localhost:5000",
    "CatalogService": "http://localhost:5002",
    "RuleService": "http://localhost:5004"
  },
  "Authentication": {
    "Authority": "http://localhost:5001",
    "Issuer": "gss-web-api",
    "Audience": "gss-web-api",
