# Environment Variables for GSS Web API (BFF)

# Service Endpoints (required)
ServiceEndpoints__AdminService=http://admin-service:8080
ServiceEndpoints__CatalogService=http://catalog-service:8080
ServiceEndpoints__RuleService=http://rule-service:8080

# Authentication (required)
Authentication__Authority=https://cognito-idp.ap-south-1.amazonaws.com/ap-south-1_XXXXXXXXX
Authentication__Audience=gss-web-api
Authentication__ValidateIssuer=true
Authentication__ValidateAudience=true
Authentication__ValidateLifetime=true

# Resilience Settings (optional - defaults in appsettings.json)
Resilience__RetryCount=3
Resilience__RetryDelaySeconds=2
Resilience__CircuitBreakerThreshold=5
Resilience__CircuitBreakerDurationSeconds=30
Resilience__TimeoutSeconds=30

# CORS (optional - defaults in appsettings.json)
Cors__AllowedOrigins__0=https://app.gss.com
Cors__AllowedOrigins__1=https://app-staging.gss.com

# Logging Level (optional)
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning

# ASP.NET Core (required for production)
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# AWS Secrets (if using Secrets Manager)
# AWS_REGION=ap-south-1
# AWS_SECRET_NAME=gss-web-api/production
