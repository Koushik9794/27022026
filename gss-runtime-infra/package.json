{
    "name": "gss-runtime-infra",
    "version": "1.0.0",
    "description": "GSS cross-account CDK — imports existing VPC/RDS/ECR, creates ECS + ALB in runtime account 771355239306",
    "main": "bin/deploy.js",
    "scripts": {
        "build": "tsc",
        "watch": "tsc -w",
        "cdk": "cdk",
        "synth": "cdk synth",
        "diff": "cdk diff --all",
        "deploy": "cdk deploy --all --require-approval never",
        "destroy": "cdk destroy --all --force"
    },
    "devDependencies": {
        "@types/node": "22.13.4",
        "aws-cdk": "2.178.2",
        "typescript": "5.7.3",
        "ts-node": "10.9.2"
    },
    "dependencies": {
        "aws-cdk-lib": "2.178.2",
        "constructs": "10.4.2",
        "source-map-support": "0.5.21"
    }
}