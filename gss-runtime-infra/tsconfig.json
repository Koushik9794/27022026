{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "es2020"
        ],
        "declaration": true,
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "noImplicitThis": true,
        "alwaysStrict": true,
        "outDir": "dist",
        "rootDir": ".",
        "experimentalDecorators": true,
        "inlineSourceMap": true,
        "inlineSources": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true
    },
    "include": [
        "bin/**/*.ts",
        "lib/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}