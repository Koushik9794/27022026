{
    "name": "gss-infra",
    "version": "1.0.0",
    "description": "AWS CDK infrastructure for GSS Backend — admin-service deployment",
    "main": "bin/gss-infra.js",
    "scripts": {
        "build": "tsc",
        "watch": "tsc -w",
        "cdk": "cdk",
        "deploy": "cdk deploy --all --require-approval never",
        "destroy": "cdk destroy --all --force",
        "synth": "cdk synth",
        "diff": "cdk diff"
    },
    "devDependencies": {
        "@types/node": "22.13.4",
        "aws-cdk": "2.178.2",
        "typescript": "5.7.3"
    },
    "dependencies": {
        "aws-cdk-lib": "2.178.2",
        "constructs": "10.4.2",
        "source-map-support": "0.5.21"
    }
}